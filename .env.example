# Optional SMTP configuration for weekly email delivery.
SEMINAR_SMTP_HOST=smtp.example.com
SEMINAR_SMTP_PORT=587
SEMINAR_SMTP_USERNAME=your-username
SEMINAR_SMTP_PASSWORD=your-password
SEMINAR_SMTP_STARTTLS=true
SEMINAR_SMTP_SSL=false
SEMINAR_EMAIL_FROM=seminars@example.com
SEMINAR_EMAIL_TO=you@example.com

